# Supabase (서버 전용 서비스 키)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Reddit API (Phase 1.5 활성화 시 발급: reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# YouTube Data API v3 (LLM 비용 검증 후 활성화: Google Cloud Console)
YOUTUBE_API_KEY=

# Claude API (유튜브 요약 활성화 시: console.anthropic.com)
ANTHROPIC_API_KEY=

# 이메일 발송 (resend.com)
RESEND_API_KEY=

# ETF holdings (선택: etfdb.com)
ETFDB_API_KEY=
